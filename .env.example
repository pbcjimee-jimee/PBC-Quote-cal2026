# Optional alias for JOBBER_REDIRECT_URI.
JOBBER_CALLBACK_URL=
JOBBER_GRAPHQL_VERSION=2025-04-16
# Optional development fallback. Production quote fetch uses OAuth tokens stored in Supabase.
JOBBER_ACCESS_TOKEN=
