NEXT_PUBLIC_SUPABASE_URL=
# Preferred current Supabase key name. A legacy anon key also works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional local-only bypass. Leave unset/false when using Supabase auth and DB locally.
NEXT_PUBLIC_DEV_NO_AUTH=false
# Optional. Comma-separated emails allowed to sign in. Leave blank to allow any Supabase Auth user.
ALLOWED_LOGIN_EMAILS=

JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_TOKEN_ENCRYPTION_KEY=
JOBBER_REDIRECT_URI=http://localhost:3000/api/jobber/callback
# Optional alias for JOBBER_REDIRECT_URI.
JOBBER_CALLBACK_URL=
# Optional. Defaults to 2025-04-16 when unset.
JOBBER_GRAPHQL_VERSION=2025-04-16
# Optional development fallback. Production quote fetch uses OAuth tokens stored in Supabase.
JOBBER_ACCESS_TOKEN=
